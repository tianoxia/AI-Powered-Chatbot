{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/HX.AI-Chat/RR.AI-Chat.Api/bin/Debug/net10.0/HX.AI-Chat.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/HX.AI-Chat/HX.AI-Chat.Api",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7045;http://localhost:5247"
      }
    },
    {
      "name": "UI (Debug)",
      "type": "msedge",
      "request": "launch",
      "preLaunchTask": "serve-ui",
      "url": "http://localhost:4200/",
      "webRoot": "${workspaceFolder}/ai-chat-ui",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "API + UI (Debug)",
      "configurations": ["API (Debug)", "UI (Debug)"],
      "stopAll": true
    }
  ]
}